NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deskline
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CometChat (server-side only — never expose these to clients) ───
# Your CometChat application ID (found in CometChat Dashboard > App Settings)
COMETCHAT_APP_ID=your_app_id_here
# CometChat region: "us" or "eu" (must match the region selected during app creation)
COMETCHAT_REGION=us
# REST API Key for server-to-server calls (Dashboard > API & Auth Keys)
COMETCHAT_REST_API_KEY=your_rest_api_key_here
# Webhook signature secret for validating incoming CometChat webhook payloads
COMETCHAT_WEBHOOK_SECRET=your_webhook_secret_here
# UID of the CometChat AI Agent used for Information ticket conversations
COMETCHAT_AI_AGENT_UID=your_ai_agent_uid_here
