generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  employee
  agent
  supervisor
  admin
}

enum Department {
  IT
  HR
  General
}

enum TicketCategory {
  IT
  HR
  General
}

enum TicketSubType {
  information
  action
  conversation
  escalation
}

enum TicketPriority {
  low
  medium
  high
}

enum TicketStatus {
  open
  in_progress
  escalated
  resolved
  closed
}

enum NotificationType {
  ticket_update
  assignment
  escalation
  announcement
  cometchat
}

enum ModerationStatus {
  pending
  dismissed
  blocked
}

enum ModerationAction {
  dismiss
  block_sender
}

enum WebhookStatus {
  received
  processed
  failed
}

model User {
  id                String         @id @default(uuid())
  name              String
  email             String         @unique
  passwordHash      String         @map("password_hash")
  role              UserRole
  department        Department
  isActive          Boolean        @default(true) @map("is_active")
  lastLoginAt       DateTime?      @map("last_login_at")
  lastFailedLoginAt DateTime?      @map("last_failed_login_at")
  cometchatUid      String?        @map("cometchat_uid")
  fcmToken          String?        @map("fcm_token")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  tickets           Ticket[]       @relation("EmployeeTickets")
  assignedTickets   Ticket[]       @relation("AgentTickets")
  notifications     Notification[]
  activityLogs      ActivityLog[]
  refreshTokens     RefreshToken[]
  ticketComments    TicketComment[]

  @@map("users")
}

model RefreshToken {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Ticket {
  id               String         @id @default(uuid())
  title            String
  description      String
  category         TicketCategory
  subType          TicketSubType  @map("sub_type")
  priority         TicketPriority
  status           TicketStatus   @default(open)
  employeeId       String         @map("employee_id")
  agentId          String?        @map("agent_id")
  lastActivityAt   DateTime?      @map("last_activity_at")
  resolvedAt       DateTime?      @map("resolved_at")
  resolutionConfirmationRequestedAt DateTime? @map("resolution_confirmation_requested_at")
  closedAt         DateTime?      @map("closed_at")
  cometchatConvoId String?        @map("cometchat_convo_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  employee         User           @relation("EmployeeTickets", fields: [employeeId], references: [id])
  agent            User?          @relation("AgentTickets", fields: [agentId], references: [id])
  comments         TicketComment[]

  @@index([employeeId])
  @@index([agentId])
  @@index([status])
  @@index([category, status])
  @@index([subType, status])
  @@map("tickets")
}

model TicketComment {
  id        String   @id @default(uuid())
  ticketId  String   @map("ticket_id")
  userId    String   @map("user_id")
  body      String
  isAi      Boolean  @default(false) @map("is_ai")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([ticketId, createdAt])
  @@map("ticket_comments")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

model ModerationQueueItem {
  id             String            @id @default(uuid())
  messageId      String            @map("message_id")
  conversationId String            @map("conversation_id")
  ticketId       String?           @map("ticket_id")
  senderUid      String            @map("sender_uid")
  senderName     String            @map("sender_name")
  messageContent String            @map("message_content")
  flagReason     String            @map("flag_reason")
  flaggedAt      DateTime          @map("flagged_at")
  status         ModerationStatus  @default(pending)
  reviewedBy     String?           @map("reviewed_by")
  reviewedAt     DateTime?         @map("reviewed_at")
  action         ModerationAction?
  createdAt      DateTime          @default(now()) @map("created_at")

  @@index([status])
  @@index([flaggedAt])
  @@map("moderation_queue")
}

model WebhookEventLog {
  id           String        @id @default(uuid())
  eventType    String        @map("event_type")
  payload      Json
  status       WebhookStatus @default(received)
  errorMessage String?       @map("error_message")
  processedAt  DateTime?     @map("processed_at")
  createdAt    DateTime      @default(now()) @map("created_at")

  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@map("webhook_event_logs")
}
