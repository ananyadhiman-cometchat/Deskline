# ============================================================
# Staging server .env — copy to .env on the server and fill in.
# Used by docker-compose.prod.yml on deskline-cometchat-staging.com.
# ============================================================

# ---- Postgres (container) ----
POSTGRES_USER=deskline
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=deskline

# ---- Backend ----
NODE_ENV=production
PORT=4000

# Backend connects to the db service over the compose network on hostname "db".
DATABASE_URL=postgresql://deskline:replace-with-strong-password@db:5432/deskline

# JWT secrets — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace-with-64-byte-hex
JWT_REFRESH_SECRET=replace-with-different-64-byte-hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated list of browser origins allowed to call the API.
# Same-origin requests (host nginx -> backend) skip CORS, but mobile / external
# clients still hit this list. Add the staging origin and any test tools.
CORS_ORIGINS=https://deskline-cometchat-staging.com

# ---- AI / Firebase (server-side) ----
GEMINI_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# IMPORTANT: keep \n escapes intact when pasting the private key.
FIREBASE_PRIVATE_KEY=

# ---- Web (Vite build-time, baked into the JS bundle) ----
# Empty VITE_API_URL = SPA calls /api/* same-origin, host nginx routes to backend.
VITE_API_URL=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
