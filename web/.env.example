# ─── CometChat (client-side — VITE_ prefix exposes these in the browser bundle) ───
# Your CometChat application ID (same as backend COMETCHAT_APP_ID)
VITE_COMETCHAT_APP_ID=your_app_id_here
# CometChat region: "us" or "eu" (must match backend COMETCHAT_REGION)
VITE_COMETCHAT_REGION=us
# NOTE: Auth tokens are generated server-side. Never place the Auth Key or REST API Key here.
